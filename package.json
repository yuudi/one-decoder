{
  "name": "one-decoder",
  "version": "1.1.1",
  "private": true,
  "scripts": {
    "build": "ng build",
    "lint": "ng lint --fix && prettier . --write",
    "ng": "ng",
    "start": "ng serve ${REMOTE_CONTAINERS:+--host 0.0.0.0}",
    "watch": "ng build --watch --configuration development"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-packagejson"
    ],
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "abracadabra-cn": "^3.3.3",
    "bs58": "^6.0.0",
    "cherugo": "git+https://github.com/yuudi/cherugo.js",
    "crypto-js": "^4.2.0",
    "entities": "^8.0.0",
    "hi-base32": "^0.5.1",
    "hidden-watermark-wasm": "git+https://github.com/yuudi/one-decoder.git#hidden-watermark-wasm",
    "punycode": "^2.3.1",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "whisperer-wasm": "git+https://github.com/yuudi/one-decoder.git#whisperer-wasm",
    "zero-width-lib": "^1.1.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@types/crypto-js": "^4.2.2",
    "@types/jasmine": "~6.0.0",
    "@types/punycode": "^2.1.4",
    "@types/qrcode": "^1.5.6",
    "angular-eslint": "21.3.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "~6.1.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "npm-check-updates": "^20.0.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
